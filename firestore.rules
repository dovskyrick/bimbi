rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /paintings/{paintingId} {
      allow read: if true;
      // Allow writes only from the admin Firebase account (replace YOUR_UID_HERE — see admin-web-setup.md)
      allow write: if request.auth != null
                   && request.auth.uid == 'FIKLPr4iWNcjNkUheiC5Cqari162';
    }

    match /orders/{orderId} {
      allow read: if false;
      allow write: if false;
    }
  }
}
